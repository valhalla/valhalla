{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    "boost-algorithm",
    "boost-foreach",
    "boost-format",
    "boost-geometry",
    "boost-heap",
    "boost-optional",
    "boost-property-tree",
    "boost-range",
    "boost-tokenizer",
    "curl",
    "cxxopts",
    "date",
    {
      "name": "dirent",
      "platform": "windows"
    },
    {
      "name": "gdal",
      "default-features": false
    },
    "geos",
    {
      "name": "libspatialite",
      "default-features": true,
      "features": ["rttopo"]
    },
    "pkgconf",
    "rapidjson",
    "nanobind",
    "spatialite-tools",
    "luajit",
    "protobuf",
    "sqlite3",
    "zlib",
    "unordered-dense",
    "libosmium",
    "openssl"
  ],
  "features": {
    "elevation-lz4": {
      "description": "LZ4 decompression support for elevation tiles",
      "dependencies": ["lz4"]
    },
    "services": {
      "description": "ZMQ + prime_server multiprocess HTTP service. Activate from CMake by setting VCPKG_MANIFEST_FEATURES=services. Only needed for the standalone valhalla_service binary; Python wheels and the embedded library don't need it.",
      "dependencies": [
        {
          "name": "zeromq",
          "platform": "windows"
        },
        {
          "name": "czmq",
          "platform": "windows"
        },
        {
          "name": "prime-server",
          "platform": "windows"
        }
      ]
    }
  },
  "default-features": ["elevation-lz4"]
}
